# ================================================
# BE-INVEST DOCKER DEPLOYMENT ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env and update with your values

# ================================================
# LANGFUSE CONFIGURATION
# ================================================
# Get these from Langfuse after setting up API keys in the web interface
# Visit: http://localhost:3000/settings/api-keys
LANGFUSE_PUBLIC_KEY=pk_prod_your_public_key_here
LANGFUSE_SECRET_KEY=sk_prod_your_secret_key_here

# Langfuse host is set automatically in docker-compose.yml
# For local Docker: http://langfuse-server:3000
# For external Langfuse: https://cloud.langfuse.com

# ================================================
# LLM API KEYS
# ================================================
# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk_ant_your_api_key_here

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=sk_your_openai_key_here

# Google (Gemini models)
GOOGLE_API_KEY=your_google_api_key_here

# Groq (High-speed open LLMs)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ================================================
# APPLICATION SETTINGS
# ================================================
# CORS Origins - allow specific domains
# For development: CORS_ORIGINS=*
# For production: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# News scraping interval in hours (default: 24)
NEWS_SCRAPE_INTERVAL_HOURS=24

# ================================================
# EMAIL REPORT SCHEDULER
# ================================================
# Gmail: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=your-gmail@gmail.com
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com
EMAIL_SEND_HOUR_UTC=8
EMAIL_SCHEDULER_ENABLED=true
# Set to true if behind a corporate proxy / SSL inspection (disables cert verification)
SMTP_SKIP_VERIFY=false

# ================================================
# DOCKER COMPOSE SETTINGS (Optional)
# ================================================
# Uncomment to override container names or ports
# BE_INVEST_PORT=8000
# LANGFUSE_PORT=3000
# LANGFUSE_DB_PORT=5433

# ================================================
# OPTIONAL: EXTERNAL LANGFUSE CONFIGURATION
# ================================================
# If you're using Langfuse Cloud or an external instance, 
# set LANGFUSE_HOST to your external URL instead of the Docker service name:
# LANGFUSE_HOST=https://cloud.langfuse.com
